<mujoco model="F1">
  <!--
    F1_simple.xml: F1机器人用于MuJoCo sim2sim仿真的简化碰撞体版本。
    与F1.xml的区别：
      - 视觉geom完全保留（class="visual"，不参与碰撞）
      - 碰撞体（class="collision" type="mesh"）替换为基本几何体（capsule/sphere），
        参照F1_simple_collision.urdf的简化方案：
          · pelvis: 2个sphere覆盖臀部
          · left/right_hip_pitch_link: 4段capsule描述大腿
          · left/right_knee_link: 1段capsule描述小腿
          · left/right_ankle_roll_link: 10个foot sphere（增密版，提升足底接触稳定性）
          · waist_yaw_link: capsule躯干 + 2个chest sphere
          · 其余连接件（hip_roll, hip_yaw, ankle_pitch, waist_pitch/roll, 全部臂部link）：移除碰撞体
    惯性参数与关节定义与F1.xml完全一致。
  -->
  <compiler meshdir="../meshes/" autolimits="true" angle="radian" />
  <default>
    <default class="F1">
      <site rgba="1 0 0 1" size="0.01" group="5" />
      <joint damping="0.0" armature="0.03" frictionloss="0.3" />
      <default class="visual">
        <geom group="2" type="mesh" contype="0" conaffinity="0" density="0" />
      </default>
      <default class="collision">
        <geom group="3" type="mesh" />
        <default class="foot">
