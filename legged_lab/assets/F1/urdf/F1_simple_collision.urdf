      <origin xyz="0.04 -0.015 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
    <collision>
      <origin xyz="0.085 0.03 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
    <collision>
      <origin xyz="0.085 -0.03 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
    <collision>
      <origin xyz="0.13 0.035 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
    <collision>
      <origin xyz="0.13 -0.035 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
   </link>
   <joint name="left_ankle_roll_joint" type="revolute">
     <origin xyz="0 0 0" rpy="0 0 0" />
     <parent link="left_ankle_pitch_link" />
     <child link="left_ankle_roll_link" />
     <axis xyz="1 0 0" />
     <limit lower="-0.2618" upper="0.2618" effort="28.978" velocity="3.6549" />
   </joint>
 
   <!-- ====================== RIGHT LEG ====================== -->
 
   <!-- right_hip_roll_link: 小型连接件，移除碰撞 -->
   <link name="right_hip_roll_link">
     <inertial>
       <origin xyz="0.001779 -0.020882 -1.841E-06" rpy="0 0 0" />
       <mass value="1.8" />
       <inertia ixx="0.0028728" ixy="-0.00011112" ixz="0" iyy="0.0031773" iyz="0" izz="0.0026719" />
