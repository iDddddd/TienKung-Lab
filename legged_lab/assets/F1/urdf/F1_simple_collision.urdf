       <material name=""><color rgba="0.89804 0.91765 0.92941 1" /></material>
     </visual>
     <!-- 手部 box 保守缩小，避免与前臂/身体产生自碰撞 -->
     <collision>
       <origin xyz="0.015 -0.045 -0.015" rpy="0 0 0" />
       <geometry><box size="0.045 0.060 0.030" /></geometry>
     </collision>
   </link>
   <joint name="right_wrist_roll_joint" type="revolute">
