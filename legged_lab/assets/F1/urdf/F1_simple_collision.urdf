     <axis xyz="0 0 1" />
     <limit lower="-0.34907" upper="0.34907" effort="3" velocity="16.441" />
   </joint>
 
   <!-- right_wrist_pitch_link: 手指处，移除碰撞 -->
   <link name="right_wrist_pitch_link">
     <inertial>
       <origin xyz="0.014692 -0.076244 -0.018529" rpy="0 0 0" />
       <mass value="0.4" />
       <inertia ixx="0.0032648" ixy="-0.000456" ixz="-0.00013419" iyy="0.00054067" iyz="0.00071989" izz="0.0033129" />
