<?xml version="1.0" encoding="utf-8"?>
 <!-- F1_simple_collision.urdf: 将腿部/手臂复杂mesh碰撞体替换为基本几何体，
      适合导入IsaacLab进行强化学习训练（降低碰撞计算开销、避免mesh碰撞不稳定）。
      视觉保持mesh，惯性参数与F1.urdf完全一致。 -->
 <robot name="F1">
   <mujoco>
     <compiler meshdir="../meshes/" balanceinertia="true" discardvisual="false" />
   </mujoco>
 
   <!-- ======================== pelvis ======================== -->
   <link name="pelvis">
     <inertial>
       <origin xyz="0.03248 -2.2731E-08 0.062366" rpy="0 0 3.14159265358979" />
       <mass value="7.2" />
       <inertia ixx="0.09796773" ixy="0" ixz="-0.02179488" iyy="0.0983936" iyz="0" izz="0.10472194" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 3.14159265358979" />
       <geometry><mesh filename="meshes/pelvis.STL" /></geometry>
       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
     <!-- 两个球体近似左右臀部，贴合屁股形状便于坐下等动作 -->
     <!-- 左臀：x=-0.04(后侧), y=+0.055, z=-0.015(下方) -->
     <collision>
       <origin xyz="-0.03 0.06 -0.018" rpy="0 0 0" />
       <geometry><sphere radius="0.065" /></geometry>
     </collision>
     <!-- 右臀：与左臀对称 -->
     <collision>
       <origin xyz="-0.03 -0.06 -0.018" rpy="0 0 0" />
       <geometry><sphere radius="0.065" /></geometry>
     </collision>
   </link>
 
   <!-- ====================== LEFT LEG ======================= -->
 
   <!-- left_hip_roll_link: 小型连接件，移除网格碰撞 -->
   <link name="left_hip_roll_link">
     <inertial>
       <origin xyz="0.001779 0.020882 1.8535E-06" rpy="0 3.14159265358979 0" />
       <mass value="1.8" />
       <inertia ixx="0.00287278" ixy="-0.00011112" ixz="0" iyy="0.00317726" iyz="0" izz="0.00267187" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 3.14159265358979 0" />
       <geometry><mesh filename="meshes/left_hip_roll_link.STL" /></geometry>
       <material name=""><color rgba="0.75294 0.75294 0.75294 1" /></material>
     </visual>
     <!-- 无碰撞（小型连接件） -->
   </link>
   <joint name="left_hip_roll_joint" type="revolute">
     <origin xyz="0.0310099999959327 0.0660000000000372 -0.0522173304559107" rpy="0 0 0" />
     <parent link="pelvis" />
     <child link="left_hip_roll_link" />
     <axis xyz="1 0 0" />
     <limit lower="-0.34907" upper="0.87266" effort="60" velocity="13.09" />
   </joint>
 
   <!-- left_hip_pitch_link: 髋关节俯仰连接件，圆柱近似电机壳体（"大屁股"特征） -->
   <link name="left_hip_pitch_link">
     <inertial>
       <origin xyz="-0.0063393 0.038449 -0.040823" rpy="0 3.14159265358979 0" />
       <mass value="2.3" />
       <inertia ixx="0.016845" ixy="0.00045424" ixz="0.00037614" iyy="0.018463" iyz="0.0020361" izz="0.020387" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 3.14159265358979 0" />
       <geometry><mesh filename="meshes/left_hip_pitch_link.STL" /></geometry>
       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
     <!-- 无碰撞（与相邻关节重叠无法避免，视觉保留mesh） -->
   </link>
   <joint name="left_hip_pitch_joint" type="revolute">
     <origin xyz="0 0 0" rpy="0 0 0" />
     <parent link="left_hip_roll_link" />
     <child link="left_hip_pitch_link" />
     <axis xyz="0 1 0" />
     <limit lower="-2.0944" upper="0.17453" effort="60" velocity="13.09" />
   </joint>
 
   <!-- left_hip_yaw_link: 大腿段(~370mm)，用多段圆柱近似。膝盖附近收窄，避免屈膝自碰撞。 -->
   <link name="left_hip_yaw_link">
     <inertial>
       <origin xyz="-0.0034111 0.0040172 -0.21195" rpy="0 0 0" />
       <mass value="1.9" />
       <inertia ixx="0.098131" ixy="0.00027487" ixz="0.0020213" iyy="0.099231" iyz="-0.0010082" izz="0.0093196" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry><mesh filename="meshes/left_hip_yaw_link.STL" /></geometry>
       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
     <!-- 上段：缩小并下移，避免与 pelvis mesh 自碰撞 -->
     <collision>
       <origin xyz="0 0 -0.13" rpy="0 0 0" />
       <geometry><cylinder radius="0.040" length="0.06" /></geometry>
     </collision>
     <!-- 中上段：大腿主要体积，避开膝盖附近 -->
     <collision>
       <origin xyz="-0.012 0 -0.195" rpy="0 0 0" />
       <geometry><cylinder radius="0.050" length="0.10" /></geometry>
     </collision>
     <!-- 中下段：开始收窄，补足大腿下半段但不侵入膝关节空间 -->
     <collision>
       <origin xyz="-0.020 0 -0.275" rpy="0 0 0" />
       <geometry><cylinder radius="0.040" length="0.060" /></geometry>
     </collision>
     <!-- 下段：靠近膝关节的细圆柱，给小腿上端留出屈膝空间 -->
     <collision>
       <origin xyz="-0.028 0 -0.335" rpy="0 0 0" />
       <geometry><cylinder radius="0.026" length="0.035" /></geometry>
     </collision>
     <!-- 关节处偏置小圆柱：只保留很小的末端覆盖，避免和小腿上端互顶 -->
     <collision>
       <origin xyz="-0.034 0 -0.370" rpy="0 0 0" />
       <geometry><cylinder radius="0.012" length="0.010" /></geometry>
     </collision>
   </link>
   <joint name="left_hip_yaw_joint" type="revolute">
     <origin xyz="0 0.0119999999999601 0" rpy="0 -0.0174532925199601 0" />
     <parent link="left_hip_pitch_link" />
     <child link="left_hip_yaw_link" />
     <axis xyz="0 0 1" />
     <limit lower="-0.87266" upper="1.5708" effort="36" velocity="13.614" />
   </joint>
 
  <!-- left_knee_link: 小腿段(~411mm)，用两段圆柱近似。上端收窄，整体延长以贴近视觉小腿。 -->
   <link name="left_knee_link">
     <inertial>
       <origin xyz="-0.015112 0.0018999 -0.18828" rpy="0 0 0" />
       <mass value="1.3" />
       <inertia ixx="0.084815" ixy="-6.89E-05" ixz="0.0041094" iyy="0.08528" iyz="-0.00027868" izz="0.0030214" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry><mesh filename="meshes/left_knee_link.STL" /></geometry>
       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
    <!-- 小腿上段：向膝盖方向延长但保持细，避免屈膝时与大腿末端自碰撞 -->
    <collision>
      <origin xyz="0 0 -0.125" rpy="0 0 0" />
      <geometry><cylinder radius="0.028" length="0.13" /></geometry>
    </collision>
    <!-- 小腿主体：下端收在脚踝上方，避免伸进脚部碰撞体 -->
    <collision>
      <origin xyz="0 0 -0.300" rpy="0 0 0" />
      <geometry><cylinder radius="0.030" length="0.16" /></geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.060" rpy="0 0 0" />
      <geometry><sphere radius="0.028" /></geometry>
    </collision>
    <collision>
      <origin xyz="0 0 -0.380" rpy="0 0 0" />
      <geometry><sphere radius="0.030" /></geometry>
    </collision>
  </link>
   <joint name="left_knee_joint" type="revolute">
     <origin xyz="-0.036584110610468 -0.00349999999999995 -0.369445360283527" rpy="0 0.0235973553628798 0" />
     <parent link="left_hip_yaw_link" />
     <child link="left_knee_link" />
     <axis xyz="0 1 0" />
     <limit lower="0" upper="2.618" effort="60" velocity="13.09" />
   </joint>
 
   <!-- left_ankle_pitch_link: 微型连接件，移除碰撞 -->
   <link name="left_ankle_pitch_link">
     <inertial>
       <origin xyz="0.003189 -0.00023136 7.7566E-08" rpy="0 0 0" />
       <mass value="0.0092686" />
       <inertia ixx="2.002E-07" ixy="1.6689E-12" ixz="-4.4717E-13" iyy="1.09E-06" iyz="-3.308E-10" izz="8.4367E-07" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry><mesh filename="meshes/left_ankle_pitch_link.STL" /></geometry>
       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
     <!-- 无碰撞 -->
   </link>
   <joint name="left_ankle_pitch_joint" type="revolute">
     <origin xyz="0.0156729311625504 0 -0.410797223978904" rpy="0 0 0" />
     <parent link="left_knee_link" />
     <child link="left_ankle_pitch_link" />
     <axis xyz="0 1 0" />
     <limit lower="-0.43633" upper="0.7854" effort="21.213" velocity="1.6499" />
   </joint>
 
  <!-- left_ankle_roll_link: 足部，用10点球近似足底接触 -->
   <link name="left_ankle_roll_link">
     <inertial>
       <origin xyz="0.029519 0.0033792 -0.027493" rpy="0 0 0" />
       <mass value="0.7" />
       <inertia ixx="0.00080149" ixy="0.00014242" ixz="-0.00069678" iyy="0.00283614" iyz="-7.132E-05" izz="0.00238444" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 0" />
       <geometry><mesh filename="meshes/left_ankle_roll_link.STL" /></geometry>
       <material name=""><color rgba="0.75294 0.75294 0.75294 1" /></material>
     </visual>
    <collision>
      <origin xyz="-0.05 0.02 -0.055" rpy="0 0 0" />
      <geometry><sphere radius="0.005" /></geometry>
    </collision>
    <collision>
      <origin xyz="-0.05 -0.02 -0.055" rpy="0 0 0" />
