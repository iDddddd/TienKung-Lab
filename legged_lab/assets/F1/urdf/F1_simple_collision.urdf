       <material name=""><color rgba="0.89804 0.91765 0.92941 1" /></material>
     </visual>
     <!-- 无碰撞 -->
   </link>
   <joint name="right_wrist_yaw_joint" type="revolute">
     <origin xyz="0.00199999999805286 -0.0939999458229315 0" rpy="0 0 0" />
     <parent link="right_elbow_link" />
     <child link="right_wrist_yaw_link" />
     <axis xyz="0 1 0" />
     <limit lower="-0.87266" upper="0.87266" effort="6" velocity="12.566" />
   </joint>
 
   <!-- right_wrist_roll_link: 手部用box近似(沿-y展开) -->
   <link name="right_wrist_roll_link">
     <inertial>
       <origin xyz="-2.3929E-10 -4.9855E-09 0.0010567" rpy="0 0 0" />
       <mass value="0.0018868" />
       <inertia ixx="1.584E-08" ixy="1.2193E-12" ixz="1.2828E-13" iyy="1.1887E-07" iyz="-1.0263E-13" izz="1.0848E-07" />
