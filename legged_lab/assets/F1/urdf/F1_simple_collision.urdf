       <material name=""><color rgba="1 1 1 1" /></material>
     </visual>
     <!-- 前臂碰撞体缩短变细，避开肘/腕关节附近的自碰撞 -->
     <collision>
       <origin xyz="0 -0.145 0" rpy="1.5708 0 0" />
       <geometry><cylinder radius="0.025" length="0.080" /></geometry>
     </collision>
   </link>
   <joint name="right_elbow_joint" type="revolute">
     <origin xyz="-0.00879978664812137 -0.133000000000268 -0.010000000002981" rpy="0 0 -1.08299254783319E-05" />
     <parent link="right_shoulder_yaw_link" />
     <child link="right_elbow_link" />
     <axis xyz="0 0 1" />
     <limit lower="0" upper="2.35619449" effort="6" velocity="12.566" />
   </joint>
 
   <!-- right_wrist_yaw_link: 微型连接件，移除碰撞 -->
   <link name="right_wrist_yaw_link">
     <inertial>
       <origin xyz="0.002125 -0.044994 0.0019286" rpy="0 0 0" />
       <mass value="0.052405" />
       <inertia ixx="0.00018236" ixy="2.7274E-06" ixz="-2.4434E-07" iyy="9.5628E-06" iyz="3.2468E-06" izz="0.0001827" />
     </inertial>
     <visual>
       <origin xyz="0 0 0" rpy="0 0 0" />
